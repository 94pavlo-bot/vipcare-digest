: flex; justify-content: space-between; align-items: center; padding: 32px 64px; } .br { font-size: 11px; font-weight: 700; letter-spacing: 5px; text-transform: uppercase; color: #404055; } .tg { font-size: 10px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: #E8002E; border: 1px solid rgba(232,0,46,0.3); padding: 5px 16px; } .bd { flex: 1; display: flex; align-items: center; gap: 56px; padding: 0 64px; } .left { flex: 0 0 600px; } .h { font-size: 74px; font-weight: 900; line-height: 1.05; letter-spacing: -2px; white-space: nowrap; } .r { color: #E8002E; } .right { flex: 1; padding-left: 24px; border-left: 1px solid #1A1A22; } .bi { font-size: 18px; line-height: 1.6; color: #A0A0B8; margin-bottom: 10px; } .bi b { color: #F4F4F8; } .bi .rd { color: #E8002E; font-weight: 700; } .ft { display: flex; justify-content: space-between; align-items: center; padding: 12px 64px 28px; border-top: 1px solid #1A1A22; } .hl { font-size: 13px; font-weight: 700; letter-spacing: 2px; color: #404055; } .si { font-size: 11px; color: #28283A; letter-spacing: 2px; }</style></head><body><div class=\"c\"><div class=\"acc\"></div><div class=\"hd\"><div class=\"br\">VIPCare.io</div><div class=\"tg\">Hot Take</div></div><div class=\"bd\"><div class=\"left\"><div class=\"h\">VIP-сервис<br>узнал столик.<br><span class=\"r\">Не игрока.</span></div></div><div class=\"right\"><div class=\"bi\">За <b>14 дней</b> - десятки арестов по прокси-ставкам в Макао.</div><div class=\"bi\">Метод: <b>футболка с дырками</b> под камеру телефона.</div><div class=\"bi\">Все <b>шесть концессионеров</b> сели за стол с DICJ.</div><div class=\"bi\">Личный сервис <span class=\"rd\">не заметил подмену.</span></div></div></div><div class=\"ft\"><div class=\"hl\">@vipcare_io</div><div class=\"si\">vipcare.io</div></div></div></body></html>\n"}], "queue": [{"text": "bet-at-home перевела часть CRM на естественный язык.\n\nОператор на Франкфуртской бирже с 1999 года подключил Fast Track AI - агентный слой поверх CRM, Rewards и Greco.\n\nРаньше бонусную механику собирали втроём: аналитик считает сегмент, маркетолог пишет условия, разработчик встраивает триггер. Дни работы.\n\nТеперь хост формулирует задачу словами - и агент строит кампанию сам.\n\nОдин промпт вместо отдела.\n\nVIP-хост остаётся там, где решают отношения, а не логика.\n\nВсё остальное уже забрал агент.\n\n@vipcare_io", "image_html": null}, {"text": "Луис Руджеро сам прошёл через игровую зависимость. Выкарабкался - и теперь методично разбирает индустрию, которая его туда привела.\n\nЕго проект The Gambling Truth Project в июле поднял вопрос: кто платит за NCPG - главную организацию по проблемному гемблингу в США.\n\nСписок спонсоров конференции: Bally's, FanDuel, DraftKings, Caesars, MGM, PENN, Aristocrat.\n\nСемь операторов финансируют структуру, которая должна их же и контролировать.\n\nРуджеро сказал прямо: никто не кусает руку, которая его кормит.\n\nЕго предложение - обязательный сбор с операторов через закон. Деньги идут в штаты напрямую. Без логотипа на баннере, без места в президиуме.\n\nОтветственность за вред годами оплачивает тот, кто этот вред создаёт.\n\nРезультат - как обычно.\n\n@vipcare_io", "image_html": null}], "linkedin_post": null}